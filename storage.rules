rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Organization documents
    match /organizations/{orgId}/documents/{allPaths=**} {
      // Allow read/write for authenticated org members
      // Note: In production, validate orgId against user's org
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }
    
    // User avatars
    match /users/{userId}/avatar/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024 // 5MB max
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Agent-generated files
    match /organizations/{orgId}/agent-outputs/{allPaths=**} {
      allow read: if request.auth != null;
      // Only Cloud Functions write agent outputs
      allow write: if false;
    }
    
    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
