rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user's org ID from their user document
    function getUserOrgId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId;
    }
    
    // Helper function to check if user belongs to the organization
    function isOrgMember(orgId) {
      return isAuthenticated() && getUserOrgId() == orgId;
    }
    
    // Helper function to check if user is admin of the organization
    function isOrgAdmin(orgId) {
      return isAuthenticated() && 
             getUserOrgId() == orgId && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ─── User Documents ─────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Users can create their own profile during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can update their own profile
      allow update: if isAuthenticated() && request.auth.uid == userId;
      // Only admins can delete users (handled server-side)
      allow delete: if false;
    }
    
    // ─── Organization Documents ──────────────────────────────────────
    match /organizations/{orgId} {
      // Org members can read their organization
      allow read: if isOrgMember(orgId);
      // Only during signup (creating a new org)
      allow create: if isAuthenticated();
      // Only admins can update org settings
      allow update: if isOrgAdmin(orgId);
      // Prevent org deletion from client
      allow delete: if false;
      
      // ─── Accounts ─────────────────────────────────────────────────
      match /accounts/{accountId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // ─── Contacts ─────────────────────────────────────────────────
      match /contacts/{contactId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // ─── Deals ────────────────────────────────────────────────────
      match /deals/{dealId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // ─── Activities ───────────────────────────────────────────────
      match /activities/{activityId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgMember(orgId);
      }
      
      // ─── Documents ────────────────────────────────────────────────
      match /documents/{documentId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // ─── Insights ─────────────────────────────────────────────────
      match /insights/{insightId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // ─── Agents ───────────────────────────────────────────────────
      match /agents/{agentId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // ─── Agent Runs ───────────────────────────────────────────────
      // Runs are created by Cloud Functions, clients can only read and create (trigger)
      match /agentRuns/{runId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        // Only Cloud Functions (admin SDK) can update runs
        allow update: if false;
        allow delete: if false;
      }
      
      // ─── Agent Chat Messages ──────────────────────────────────────
      match /agents/{agentId}/messages/{messageId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if false;
        allow delete: if false;
      }
      
      // ─── Agent Templates ──────────────────────────────────────────
      match /agentTemplates/{templateId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgAdmin(orgId);
        allow update: if isOrgAdmin(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // ─── Integration Tokens (encrypted) ───────────────────────────
      // Only admins can manage integration tokens
      match /integrationTokens/{service} {
        allow read: if isOrgAdmin(orgId);
        allow write: if isOrgAdmin(orgId);
      }
      
      // ─── Notifications ────────────────────────────────────────────
      match /users/{userId}/notifications/{notifId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
        // Only Cloud Functions create notifications
        allow create: if false;
      }
    }
  }
}
